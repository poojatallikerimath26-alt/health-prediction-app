# Copy this file to .env and fill in real values. .env is git-ignored so
# secrets never get committed.

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# DB_ENGINE=sqlite uses zero-config SQLite (good for quick testing/demo)
# DB_ENGINE=mysql  uses MySQL (matches production-style setup)
DB_ENGINE=sqlite

# Only needed if DB_ENGINE=mysql
DB_NAME=health_prediction_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
